# Copie para .env e preencha. Nunca commite o .env real.

# Backend Gemma (mock | ollama | gemini) — ver backend/gemma/gemma_generate.py
GEMMA_BACKEND=gemini

# Necessário só para o backend "gemini" (Gemma hospedado via Gemini API).
# Crie grátis em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo Gemma servido pela Gemini API (opcional, tem default no código).
# Alternativa maior: gemma-4-31b-it
GEMINI_MODEL=gemma-4-26b-a4b-it

# Modelo usado APENAS para ASR (transcrição de fala) no fallback do servidor —
# NÃO é o Gemma e NÃO faz raciocínio, só converte áudio em texto quando o ASR do
# navegador (Web Speech API) não existe/falha. Ver backend/asr/transcribe.py.
# Precisa ser um modelo Gemini multimodal que aceite áudio (o Gemma rejeita áudio).
GEMINI_ASR_MODEL=gemini-flash-latest
